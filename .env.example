# Backend / deployment environment variables.
# Browser (VITE_*) variables live in frontend/.env — copy frontend/.env.example there.
#
# Production: these are set via `dokku config:set gradebee ...` on the host.
# See docs/deployment.md.

# Backend
CLERK_SECRET_KEY=sk_live_xxx
OPENAI_API_KEY=sk-xxx
ALLOWED_ORIGIN=http://localhost:5173
DB_PATH=/data/gradebee.db

# Upload directory (inside container)
UPLOADS_DIR=/data/uploads

# Hours to keep processed audio files before cleanup (default 168 = 7 days)
UPLOAD_RETENTION_HOURS=168

# Backend log level
LOG_LEVEL=DEBUG

# Sentry error reporting (optional; backend is a no-op if unset).
# In production this is baked into the Docker image via VITE_SENTRY_DSN build-arg
# (see Dockerfile Stage 3: ENV SENTRY_DSN / SENTRY_RELEASE).
# For local testing you can set it here directly.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# SENTRY_RELEASE=dev
# SENTRY_ENVIRONMENT=production   # e.g. "production", "staging" — set via dokku config:set

# LLM eval harness (cd backend && make eval).
# Set EVAL_MODEL to override the model used during eval (defaults to production model).
# EVAL_MODEL=gpt-5.4-mini
