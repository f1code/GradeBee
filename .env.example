# Backend / deployment environment variables.
# Browser (VITE_*) variables live in frontend/.env — copy frontend/.env.example there.
#
# Production: these are set via `dokku config:set gradebee ...` on the host.
# See docs/deployment.md.

# Backend
CLERK_SECRET_KEY=sk_live_xxx
# LLM provider selector: "openai" or "mistral" (default: mistral)
LLM_PROVIDER=mistral
# Provider credentials — only the active provider's key is required at runtime.
OPENAI_API_KEY=sk-xxx       # used when LLM_PROVIDER=openai
MISTRAL_API_KEY=xxx         # used when LLM_PROVIDER=mistral
# Optional base-URL overrides (rarely needed; useful for self-hosted gateways)
# OPENAI_BASE_URL=https://api.openai.com/v1
# MISTRAL_BASE_URL=https://api.mistral.ai/v1
# Per-task model IDs (provider-specific). Defaults applied if unset.
# LLM_MODEL_EXTRACTION=mistral-medium-2508    # openai default: gpt-5.4-mini
# LLM_MODEL_REPORT=mistral-medium-2508        # openai default: gpt-5.4-mini
# LLM_MODEL_VISION=mistral-medium-2508        # openai default: gpt-5.4-mini
# LLM_MODEL_TRANSCRIPTION=voxtral-mini-latest # openai default: whisper-1
# JSON parse retry overrides (integer; default: mistral=1, openai=0)
# LLM_JSON_RETRIES_MISTRAL=1
# LLM_JSON_RETRIES_OPENAI=0
ALLOWED_ORIGIN=http://localhost:5173
DB_PATH=/data/gradebee.db

# Upload directory (inside container)
UPLOADS_DIR=/data/uploads

# Hours to keep processed audio files before cleanup (default 168 = 7 days)
UPLOAD_RETENTION_HOURS=168

# Backend log level
LOG_LEVEL=DEBUG

# Sentry error reporting (optional; backend is a no-op if unset).
# In production this is baked into the Docker image via VITE_SENTRY_DSN build-arg
# (see Dockerfile Stage 3: ENV SENTRY_DSN / SENTRY_RELEASE).
# For local testing you can set it here directly.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/YYY
# SENTRY_RELEASE=dev
# SENTRY_ENVIRONMENT=production   # e.g. "production", "staging" — set via dokku config:set

# LLM eval harness (cd backend && make eval).
# Set EVAL_MODEL to override the model used during eval (defaults to the active
# provider's extraction model: LLM_MODEL_EXTRACTION or provider default).
# EVAL_MODEL=mistral-medium-2508
