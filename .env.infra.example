# .env.infra — VPS provisioning configuration
# Copy this file to .env.infra and fill in the values.
# .env.infra is gitignored. This example file is committed.
#
# Usage:
#   cp .env.infra.example .env.infra
#   # Edit .env.infra with your values
#   make infra-provision
#
# For a staging environment:
#   cp .env.infra.example .env.staging
#   # Edit .env.staging
#   ENV_FILE=.env.staging make infra-app

# ---------------------------------------------------------------------------
# SSH connection
# ---------------------------------------------------------------------------
SSH_HOST=           # VPS IP or hostname (e.g. 51.158.x.x)
SSH_USER=root       # SSH user (default: root)
SSH_PORT=22         # SSH port (default: 22)

# ---------------------------------------------------------------------------
# Dokku
# ---------------------------------------------------------------------------
DOKKU_DOMAIN=       # Primary domain for Dokku global vhost (e.g. gradebee.app)
DOKKU_VERSION=0.38.5  # Pin to a known-good release; bump deliberately

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=gradebee
GHCR_IMAGE=ghcr.io/nicogaller/gradebee:latest

# ---------------------------------------------------------------------------
# GHCR credentials (for dokku to pull images)
# ---------------------------------------------------------------------------
GHCR_USER=          # GitHub username / org owning the GHCR packages
GHCR_TOKEN=         # GitHub PAT with read:packages

# ---------------------------------------------------------------------------
# Grafana / Scaleway Cockpit (log shipping via Alloy)
# Read from Terraform outputs: cockpit_logs_push_url, cockpit_token
# ---------------------------------------------------------------------------
GRAFANA_LOKI_URL=   # e.g. https://logs.cockpit.fr-par.scaleway.com/loki/api/v1/push
COCKPIT_TOKEN=      # Scaleway Cockpit token

# ---------------------------------------------------------------------------
# S3-compatible backup storage
# Read from Terraform outputs: backup_s3_access_key, backup_s3_secret_key,
#   backup_bucket_name (for s3://<name>)
# ---------------------------------------------------------------------------
BACKUP_S3_BUCKET=   # e.g. s3://gradebee-backups
BACKUP_S3_ENDPOINT= # e.g. https://s3.fr-par.scw.cloud
BACKUP_S3_REGION=   # e.g. fr-par
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=

# ---------------------------------------------------------------------------
# Application secrets (set as Dokku config vars)
# ---------------------------------------------------------------------------
DEPLOY_SSH_PUBKEY=  # SSH public key for git-push deploys (ssh-ed25519 AAAA...)
CLERK_SECRET_KEY=   # Clerk backend API key (sk_live_xxx)
OPENAI_API_KEY=     # OpenAI API key (sk-xxx)
LETSENCRYPT_EMAIL=  # Contact email for Let's Encrypt certificates

# ---------------------------------------------------------------------------
# Application config (non-secret; defaults shown — override only if needed)
# ---------------------------------------------------------------------------
APP_DB_PATH=        # default: /data/${APP_NAME}.db
APP_UPLOADS_DIR=    # default: /data/uploads
APP_UPLOAD_RETENTION_HOURS=168   # 7 days; hours to keep processed audio files
APP_ALLOWED_ORIGIN=*             # CORS origin (* is fine; SPA is same-origin)
APP_LOG_LEVEL=INFO               # DEBUG / INFO / WARN / ERROR
APP_LOG_FORMAT=json              # json or text
