// Grafana Alloy configuration for GradeBee
// Scrapes Docker container logs and ships them to Scaleway Cockpit (Loki backend).
//
// Variables substituted by envsubst:
//   GRAFANA_LOKI_URL  - Loki push endpoint (Scaleway Cockpit)
//   COCKPIT_TOKEN     - Scaleway Cockpit token (sent as X-Token header)
//   APP_NAME          - Application name (used in log paths)

// --- Docker container logs ---
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

loki.source.docker "docker_logs" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.docker.containers.targets
  forward_to = [loki.relabel.docker_labels.receiver]
}

loki.relabel "docker_labels" {
  forward_to = [loki.write.grafana.receiver]
  rule {
    action        = "replace"
    target_label  = "job"
    replacement   = "gradebee-docker"
  }
}

// --- Backup cron log ---
local.file_match "backup_log" {
  path_targets = [
    {__path__ = "/var/log/${APP_NAME}-backup.log"},
  ]
}

loki.source.file "backup" {
  targets    = local.file_match.backup_log.targets
  forward_to = [loki.relabel.backup_labels.receiver]
}

loki.relabel "backup_labels" {
  forward_to = [loki.write.grafana.receiver]
  rule {
    action        = "replace"
    target_label  = "job"
    replacement   = "gradebee-backup"
  }
}

// --- Ship to Scaleway Cockpit (Loki) ---
loki.write "grafana" {
  endpoint {
    url = "${GRAFANA_LOKI_URL}"

    headers = {
      "X-Token" = "${COCKPIT_TOKEN}",
    }
  }
}
