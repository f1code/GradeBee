# Frontend environment variables (VITE_* are exposed to the browser bundle)
# Copy this file to .env and fill in the values for local development.

# Clerk publishable key (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Backend API base URL.
# Local dev: http://localhost:8080/api (Vite dev server proxies CORS via ALLOWED_ORIGIN)
# Production: /api (frontend is served by the Go binary, same origin as the API)
VITE_API_URL=http://localhost:8080/api

# Sentry DSN (optional diagnostics).
# When set, Sentry can be enabled only after the user opts in via the in-app
# privacy banner (error reports, feedback widget, and short session replays).
# Clerk sign-in is always necessary and is not controlled by this setting.
# Obtain from your Sentry project: Settings → Client Keys (DSN).
# Leave blank to disable Sentry entirely.
VITE_SENTRY_DSN=

# App version / release tag forwarded to Sentry (optional).
# Typically injected at build time via CI (e.g. git SHA or semver tag).
VITE_APP_VERSION=
