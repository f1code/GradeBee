{
  "name": "gradebee",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.13.0 <25"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "pnpm -F frontend dev",
    "dev:backend": "cd backend/cmd/server && go run .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.4",
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
