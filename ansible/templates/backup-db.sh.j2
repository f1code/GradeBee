#!/bin/bash
# backup-db.sh — 6-hourly SQLite backup to S3-compatible storage
# Deployed by Ansible to {{ scripts_dir }}/backup-db.sh
# App: {{ app_name }}
set -euo pipefail

# --- Configuration (set by Ansible) ---
DB_PATH="{{ data_dir }}/{{ app_name }}.db"
S3_BUCKET="{{ backup_s3_bucket }}"
# S3 key prefix: one subdirectory per app so prod and staging don't collide.
S3_PREFIX="{{ app_name }}/db"
BACKUP_RETENTION=30  # number of backups to keep

# --- Sentry Cron Monitor ---
# SENTRY_CRONS_URL format: https://<ingest-host>/api/<project-id>/cron/gradebee-backup/<public-key>/
# Set in ansible/secrets.yml. Leave empty to disable (e.g. staging).
SENTRY_CRONS_URL="{{ sentry_crons_url | default('') }}"

sentry_checkin() {
  local status="$1"
  if [ -n "${SENTRY_CRONS_URL}" ]; then
    curl -sf "${SENTRY_CRONS_URL}?status=${status}" \
      -o /dev/null --max-time 5 || true
  fi
}

# Notify Sentry the job is starting; upsert the monitor config on first run.
if [ -n "${SENTRY_CRONS_URL}" ]; then
  curl -sf "${SENTRY_CRONS_URL}" \
    -X POST -H 'Content-Type: application/json' \
    --max-time 5 \
    -d '{"monitor_config":{"schedule":{"type":"crontab","value":"0 */6 * * *"},"checkin_margin":30,"max_runtime":10,"timezone":"UTC"},"status":"in_progress"}' \
    -o /dev/null || true
fi

# On any error, notify Sentry and exit non-zero.
trap 'sentry_checkin error' ERR

# --- Timestamp ---
TIMESTAMP=$(date -u +%Y%m%dT%H%M%Sz)
TMPFILE="/tmp/{{ app_name }}-${TIMESTAMP}.db"

echo "[${TIMESTAMP}] Starting backup for {{ app_name }}..."

# --- Safe online backup (does not lock WAL writers) ---
sqlite3 "$DB_PATH" ".backup '${TMPFILE}'"
echo "  SQLite backup created: ${TMPFILE} ($(du -h "$TMPFILE" | cut -f1))"

# --- Upload to S3 ---
aws s3 cp "$TMPFILE" "${S3_BUCKET}/${S3_PREFIX}/${TIMESTAMP}.db" --quiet
echo "  Uploaded to ${S3_BUCKET}/${S3_PREFIX}/${TIMESTAMP}.db"

# --- Cleanup temp file ---
rm -f "$TMPFILE"

# --- Prune old backups (keep newest $BACKUP_RETENTION) ---
OBJECTS=$(aws s3 ls "${S3_BUCKET}/${S3_PREFIX}/" | sort | awk '{print $4}')
COUNT=$(echo "$OBJECTS" | grep -c . || true)

if [ "$COUNT" -gt "$BACKUP_RETENTION" ]; then
    DELETE_COUNT=$((COUNT - BACKUP_RETENTION))
    echo "  Pruning ${DELETE_COUNT} old backup(s) (keeping ${BACKUP_RETENTION})..."
    echo "$OBJECTS" | head -n "$DELETE_COUNT" | while read -r obj; do
        aws s3 rm "${S3_BUCKET}/${S3_PREFIX}/${obj}" --quiet
        echo "    Deleted ${obj}"
    done
fi

echo "[${TIMESTAMP}] Backup complete."

# Notify Sentry success.
sentry_checkin ok
